# Runtime logs
*.log
devspace.log
devspace.err.log

# Python caches
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local secrets and machine-specific config
.env
.env.*
*.pem
*.key
*.crt
id_rsa*
id_ed25519*

# VASP and remote-compute outputs
OUTCAR
OSZICAR
WAVECAR
CHGCAR
CHG
DOSCAR
EIGENVAL
PROCAR
vasprun.xml
XDATCAR
IBZKPT
REPORT
slurm-*.out
*.err
*.out

# Reference bundles and third-party materials
#
# Existing tracked files are not affected by .gitignore. New full reference
# bundles, generated parser caches, PDFs, images, binaries, and vendored tools
# require explicit user confirmation before staging.
vasp_references资料/**
!vasp_references资料/
!vasp_references资料/**/*.md
!vasp_references资料/**/*.txt
!vasp_references资料/**/*.yaml
!vasp_references资料/**/*.yml
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.tif
*.tiff
*.bin
*.exe
*.dll
